# ── Cross-site handoff (Path A: visitors arriving from LoomCV) ──────────────
# Must be the exact same value as LOOMCV_ATS_HANDOFF_SECRET in the LoomCV repo.
ATS_HANDOFF_SECRET=replace-with-a-long-random-string

# Base URL of your LoomCV deployment, used to call back into its internal API
# to fetch resume content once a handoff token is verified.
LOOMCV_BASE_URL=https://your-loomcv-domain.com

# ── Database (Path A persistence only — see lib/schema.prisma) ──────────────
DATABASE_URL=postgresql://user:password@host:5432/ats_scorer

# ── Ollama ────────────────────────────────────────────────────────────────
# The app calls this from the BROWSER, not the server, so this is a public
# value baked in at build time. Defaults to the standard local port.
NEXT_PUBLIC_OLLAMA_URL=http://localhost:11434
NEXT_PUBLIC_OLLAMA_MODEL=llama3:8b

# ── Premium features (cloud fallback + AI rewrite) ──────────────────────────
# Required for /api/premium/cloud-analyze and /api/premium/rewrite. Both
# routes are gated server-side by the handoff token's subscriptionTier claim
# — Path B (anonymous) visitors can never reach them regardless of this key.
GEMINI_API_KEY=

# ── Rate limiting (abuse guard only, not a usage cap — see PRD) ────────────
# Optional: leave unset to fall back to an in-memory limiter (fine for a
# single-instance deploy; use Upstash Redis once you scale beyond one region).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Links back to LoomCV shown in the results view ──────────────────────────
NEXT_PUBLIC_LOOMCV_EDITOR_URL=https://your-loomcv-domain.com
NEXT_PUBLIC_LOOMCV_SIGNUP_URL=https://your-loomcv-domain.com/sign-up
